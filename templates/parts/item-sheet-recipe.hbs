<div class="tab sheet-tab {{tabs.details.cssClass}}" data-group="primary" data-tab="{{tabs.details.id}}">
    <div class="spell-tab dod-controls">
        <table class="simple-table">
            <tr>
                <th>{{localize "TYPES.Item.skill"}}</th>
                <th>{{localize "DoD.spell.rank"}}</th>
            </tr>
            <tr>
                <td>
                    <input class="edit-school" data-field="system.school" name="system.school" type="text" value="{{localize system.school}}" />
                </td>
                <td>
                    <input name="system.rank" type="text" value="{{system.rank}}" data-dtype="Number" />
                </td>
            </tr>
        </table>

        <table class="simple-table">
            <tr>
                <th>{{localize "DoD.spell.prerequisite"}}</th>
            </tr>
            <tr>
                <td>
                    <input name="system.prerequisite" type="text" value="{{system.prerequisite}}" />
                </td>
            </tr>
        </table>
    </div>
</div>